# n8n Webhook URL
N8N_WEBHOOK_URL=http://localhost:5678/webhook/capstone-voice

# JWT Secret (change in production!)
JWT_SECRET=your-secret-key-change-this-in-production

# Google Gemini API Key (for query understanding)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI Whisper API Key (optional - for server-side STT)
OPENAI_API_KEY=

# Groq API Key (optional - free alternative for Whisper STT)
# Get from: https://console.groq.com
GROQ_API_KEY=

# Ringg AI API Key (for phone call integration)
RINGG_API_KEY=

# MongoDB connection string (for seed scripts)
MONGODB_URI=
